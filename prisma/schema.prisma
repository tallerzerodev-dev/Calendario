generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum ClassStatus {
  AVAILABLE
  BOOKED
  CANCELLED
}

model User {
  id               String      @id @default(uuid())
  email            String      @unique
  name             String?
  emailVerified    DateTime?
  image            String?
  role             Role        @default(STUDENT)
  classCredits     Int         @default(0)
  totalClassesTaken Int        @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  accounts         Account[]
  sessions         Session[]
  classSlots       ClassSlot[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Whitelist {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model WeeklyTemplate {
  id        String   @id @default(uuid())
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClassSlot {
  id        String      @id @default(uuid())
  date      DateTime
  startTime DateTime
  endTime   DateTime
  status    ClassStatus @default(AVAILABLE)
  studentId String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  student   User?       @relation(fields: [studentId], references: [id])

  @@unique([startTime])
  @@index([date, status])
  @@index([studentId, status])
}
